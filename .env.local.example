# Copy to .env.local and fill in values
# Get values from: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<publishable-anon-key>

# Generate with: SUPABASE_JWT_SECRET=<from-dashboard> node scripts/gen-jwt.mjs
# Dashboard: Project Settings -> API -> JWT Keys -> Legacy JWT Secret (HS256)
# Regenerate if JWT expires (set to 10 years — unlikely to matter for a personal tool)
VITE_USER_ID=<generated-uuid>
VITE_USER_JWT=<generated-jwt>
